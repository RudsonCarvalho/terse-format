// C.8 - Feature Flags and Remote Config
app:my-app
env:production
fetched_at:"2024-03-15T10:00:00Z"
flags:
  #[description enabled key rollout_pct]
  "Redesigned checkout flow" T new_checkout 100
  "AI product recommendations" T ai_suggestions 25
  "Dark mode UI" T dark_mode 80
  "New analytics dashboard" F beta_dashboard 0
  "CSV import (deprecated)" F legacy_importer 0
overrides:
  #[flag user_id value]
  beta_dashboard user_123 T
  ai_suggestions user_456 F
